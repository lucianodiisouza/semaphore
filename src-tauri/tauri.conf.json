{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Semaphore",
  "version": "0.1.0",
  "identifier": "dev.semaphone.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Semaphore",
        "width": 72,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Semaphore Settings",
        "url": "settings.html",
        "width": 420,
        "height": 720,
        "resizable": false,
        "decorations": true,
        "visible": false,
        "center": true,
        "skipTaskbar": false
      },
      {
        "label": "onboarding",
        "title": "Welcome to Semaphore",
        "url": "onboarding.html",
        "width": 420,
        "height": 520,
        "resizable": false,
        "decorations": true,
        "visible": false,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.semaphore/sounds/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
